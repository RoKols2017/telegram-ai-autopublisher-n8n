              "content": "={{ 'Topic: ' + $node[\"Set Inputs\"].json.topic + '\nAudience: ' + $node[\"Set Inputs\"].json.audience + '\nTone: ' + $node[\"Set Inputs\"].json.tone + '\nTelegram post text: ' + $node[\"Build Image Prompt\"].json.generated_text }}"
